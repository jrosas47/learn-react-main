# Seguridad de la cadena de suministro: no ejecutar scripts de ciclo de vida
# (preinstall/install/postinstall) de las dependencias al instalar. Evita que un
# paquete malicioso ejecute código arbitrario durante `npm install` / `npm ci`.
#
# Compatibilidad: este proyecto solo usa esbuild (vía Vite/Vitest) con un
# postinstall, y esbuild resuelve su binario desde el paquete de plataforma
# (optionalDependencies), por lo que funciona aunque el postinstall no se ejecute.
ignore-scripts=true
